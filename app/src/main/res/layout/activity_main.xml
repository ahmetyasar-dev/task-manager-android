<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FAFAFA"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Task Manager"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#111111"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gününü planla, görevlerini takip et"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="20dp" />

    <EditText
        android:id="@+id/etTaskTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Görev başlığı"
        android:background="@drawable/bg_input"
        android:layout_marginBottom="10dp"
        android:minHeight="52dp"
        android:textColor="#111111"
        android:textColorHint="#888888" />

    <EditText
        android:id="@+id/etTaskDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Görev açıklaması"
        android:background="@drawable/bg_input"
        android:layout_marginBottom="14dp"
        android:minHeight="52dp"
        android:textColor="#111111"
        android:textColorHint="#888888" />

    <Button
        android:id="@+id/btnAddSampleTask"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Görev Ekle"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_button"
        android:layout_marginBottom="18dp" />
    <EditText
        android:id="@+id/etSearchTask"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Görev ara"
        android:layout_marginBottom="16dp"
        android:minHeight="48dp"
        android:padding="12dp"
        android:background="@drawable/bg_input" />


    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Henüz görev eklenmedi"
        android:textSize="16sp"
        android:textColor="#777777"
        android:gravity="center"
        android:padding="28dp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewTasks"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="Görev listesi"
        tools:ignore="SpeakableTextPresentCheck" />

</LinearLayout>